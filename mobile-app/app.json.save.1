        {
          "icon": "./assets/notification-icon.png",
          "color": "#00c6ff",
          "sounds": []
        }
      ],
      "expo-sharing"
    ],
    "scheme": "safenetai",
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:8080/v1"
    }
