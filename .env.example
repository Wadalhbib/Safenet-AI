# SafeNet AI — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ─── Firebase Cloud Messaging ─────────────────────────────────────────────
# Required for real guardian push notifications (Step 4: Family Alert).
# Get this from: Firebase Console → Project Settings → Cloud Messaging → Server Key
# Leave as DEMO_MODE to run without Firebase (alerts will only be logged).
FIREBASE_SERVER_KEY=DEMO_MODE

# ─── Backend Server ───────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────
# SQLite database path. Default creates safenet.db in the project root.
# When using Docker, this maps to /app/data/safenet.db inside the container.
SQLITE_PATH=safenet.db

# ─── Mobile App ───────────────────────────────────────────────────────────
# For physical Android/iOS device testing, replace with your machine's local IP.
# Android emulator: 10.0.2.2 (maps to host machine localhost)
# Physical device: 192.168.x.x (your machine's IP on the local network)
EXPO_PUBLIC_API_BASE=http://10.0.2.2:8080/v1
